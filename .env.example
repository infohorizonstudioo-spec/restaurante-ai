# ═══════════════════════════════════════════════════════════════
# RESERVO.AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Core (required) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth & Security ───────────────────────────────────────────
AGENT_API_KEY=your-agent-api-key
CRON_SECRET=your-cron-secret
INTERNAL_API_KEY=your-internal-api-key

# ── AI (Claude) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice (ElevenLabs + Retell) ───────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_AGENT_ID=your-default-agent-id
RETELL_API_KEY=your-retell-key
DEEPGRAM_API_KEY=your-deepgram-key

# ── Telephony (Twilio) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+34...
TWILIO_SMS_NUMBER=+34...
TWILIO_WHATSAPP_NUMBER=+34...

# ── Payments (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_TAX_RATE_ID=txr_...

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Rate Limiting (Upstash Redis — optional) ─────────────────
# Falls back to in-memory if not set
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Push Notifications (VAPID) ───────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Monitoring (Sentry — optional) ───────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_DSN=https://...@sentry.io/...
